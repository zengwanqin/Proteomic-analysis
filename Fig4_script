read_umi_rds <- function(f) {
  con <- gzfile(f, open = "rb")
  on.exit(close(con))
  obj <- readRDS(con)
  mat <- as.matrix(obj)
  if (nrow(mat) < ncol(mat)) mat <- t(mat)
  mat
}

parse_gbm_meta_from_filename <- function(fpath) {
  fname <- basename(fpath)
  core <- sub("_umi_counts\\.RDS(\\.gz)?$", "", fname)
  parts <- strsplit(core, "_")[[1]]
  gsm_id  <- parts[1]
  pt_part <- parts[2]
  patient_raw <- sub("T[0-9]+$", "", pt_part)
  patient_id  <- sub("^P", "", patient_raw)
  time_raw <- sub("^.*T", "", pt_part)
  time_label <- dplyr::case_when(
    time_raw == "1" ~ "Primary",
    time_raw == "2" ~ "Recurrent",
    time_raw == "3" ~ "SecondRecur",
    TRUE ~ paste0("T", time_raw)
  )
  list(gsm = gsm_id, sample = pt_part, file_core = core, patient = patient_id,
       pt_label = patient_raw, time_raw = time_raw, time = time_label)
}

if (file.exists(GBM_ANNO_RDS)) {
  sce <- readRDS(GBM_ANNO_RDS)
  message("Loaded annotated IDH-wildtype GBM object: ", GBM_ANNO_RDS)
} else if (file.exists(GBM_ALL_RDS)) {
  sce <- readRDS(GBM_ALL_RDS)
  message("Loaded existing IDH-wildtype GBM object: ", GBM_ALL_RDS)
} else {
  files <- list.files(GBM_DATA_DIR, pattern = "umi_counts\\.RDS(\\.gz)?$", full.names = TRUE)
  if (length(files) == 0) stop("No umi_counts RDS files found in: ", GBM_DATA_DIR)

  seu_list <- list()
  for (f in files) {
    message("Reading: ", f)
    meta_info <- parse_gbm_meta_from_filename(f)
    counts <- read_umi_rds(f)
    colnames(counts) <- paste(meta_info$sample, colnames(counts), sep = "_")
    seu <- CreateSeuratObject(counts = counts, project = meta_info$sample,
                              min.cells = 3, min.features = 200)
    seu$GSM <- meta_info$gsm
    seu$Sample <- meta_info$sample
    seu$Patient <- meta_info$patient
    seu$Patient_label <- meta_info$pt_label
    seu$Surgery_Time_T <- meta_info$time_raw
    seu$TimePoint <- factor(meta_info$time, levels = c("Primary", "Recurrent", "SecondRecur"))
    seu_list[[meta_info$sample]] <- seu
  }
  sce <- Reduce(function(x, y) merge(x, y), seu_list)
  saveRDS(sce, GBM_ALL_RDS)
}

