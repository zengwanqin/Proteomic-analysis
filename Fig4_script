      care_id = as.character(care_id),
      patient_id_derived = sub("T[0-9]+$", "", care_id),
      timepoint_number = suppressWarnings(as.integer(sub("^.*T", "", care_id))),
      timepoint_desc = case_when(
        timepoint_number == 1 ~ "Initial",
        timepoint_number == 2 ~ "Recurrence",
        timepoint_number >= 3 ~ "Second recurrence",
        TRUE ~ NA_character_
      ),
      timepoint_desc = factor(timepoint_desc, levels = c("Initial", "Recurrence", "Second recurrence"))
    )
}

