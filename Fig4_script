gene_symbol <- function(x) {
  x <- as.character(x)
  x <- ifelse(grepl("_", x), sub("^.*_", "", x), x)
  x <- sub("\\|.*$", "", x)
  x <- sub("\\..*$", "", x)
  toupper(trimws(x))
}

format_p <- function(p) {
  p <- as.numeric(p)
  ifelse(
    is.na(p), "P = NA",
    ifelse(p < 0.0001, "P < 0.0001", paste0("P = ", formatC(p, format = "f", digits = 4)))
  )
}

safe_zscore <- function(x) {
  x <- as.numeric(x)
  sx <- sd(x, na.rm = TRUE)
  if (is.na(sx) || sx == 0) return(rep(NA_real_, length(x)))
  as.numeric((x - mean(x, na.rm = TRUE)) / sx)
}

get_r2_p <- function(fit) {
  s <- summary(fit)
  r2 <- s$r.squared
  p  <- coef(s)[2, 4]
  paste0("R² = ", round(r2, 3), "\nP = ", signif(p, 3))
}

