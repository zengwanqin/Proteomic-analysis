parse_mtx_file <- function(matrix_file) {
  bn <- basename(matrix_file)
  raw_id <- sub("^GSM[0-9]+_", "", bn)
  raw_id <- sub("_matrix\\.mtx\\.gz$", "", raw_id)
  gsm <- str_extract(bn, "^GSM[0-9]+")
  stem <- sub("_matrix\\.mtx\\.gz$", "", matrix_file)
  tibble(GSM = gsm, raw_sample_id = raw_id, format = "mtx", matrix_file = matrix_file,
         feature_file = paste0(stem, "_features.tsv.gz"), barcode_file = paste0(stem, "_barcodes.tsv.gz"))
}

parse_h5_file <- function(h5_file) {
  bn <- basename(h5_file)
  raw_id <- sub("^GSM[0-9]+_", "", bn)
  raw_id <- sub("_filtered_feature_bc_matrix\\.h5$", "", raw_id)
  gsm <- str_extract(bn, "^GSM[0-9]+")
  tibble(GSM = gsm, raw_sample_id = raw_id, format = "h5", matrix_file = h5_file,
         feature_file = NA_character_, barcode_file = NA_character_)
}

read_one_idhmut_sample <- function(manifest_row, curated_cell_ids) {
  raw_id <- manifest_row$raw_sample_id[[1]]
  fmt <- manifest_row$format[[1]]
  message("Reading IDH-mut sample: ", raw_id, " | ", fmt)

  if (fmt == "mtx") {
    counts <- Seurat::ReadMtx(
      mtx = manifest_row$matrix_file[[1]],
      features = manifest_row$feature_file[[1]],
      cells = manifest_row$barcode_file[[1]],
      feature.column = 2,
      cell.column = 1,
      unique.features = TRUE
    )
  } else if (fmt == "h5") {
    counts_raw <- Seurat::Read10X_h5(manifest_row$matrix_file[[1]], use.names = TRUE, unique.features = TRUE)
    counts <- if (is.list(counts_raw)) counts_raw[[ifelse("Gene Expression" %in% names(counts_raw), "Gene Expression", names(counts_raw)[1])]] else counts_raw
  } else {
    stop("Unsupported format: ", fmt)
  }

  original_barcodes <- colnames(counts)
  prefixed_barcodes <- paste0(raw_id, "-", original_barcodes)
  if (sum(prefixed_barcodes %in% curated_cell_ids) >= sum(original_barcodes %in% curated_cell_ids)) {
    colnames(counts) <- prefixed_barcodes
  }
  keep_cells <- intersect(colnames(counts), curated_cell_ids)
  if (length(keep_cells) == 0) return(NULL)
  counts <- counts[, keep_cells, drop = FALSE]
  seu <- CreateSeuratObject(counts = counts, project = "Nature2026_IDHmut", min.cells = 0, min.features = 0)
  seu$raw_sample_id <- raw_id
  seu$care_id_file <- manifest_row$care_id[[1]]
  seu
}

