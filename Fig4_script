extract_raw_sample_id <- function(cell_id) {
  x <- as.character(cell_id)
  y <- sub("-[ACGTN]+-[0-9]+$", "", x)
  unchanged <- y == x
  if (any(unchanged)) y[unchanged] <- sub("-[ACGTN]{12,}$", "", x[unchanged])
  y
}

derive_clinical_variables <- function(meta_df) {
  meta_df %>%
