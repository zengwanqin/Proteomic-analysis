## GSEA along malignant-cell SSI pseudotime
fisher_meta_cor <- function(expr_mat, pb_meta) {
  genes <- rownames(expr_mat)
  pts <- unique(pb_meta$Patient_label)
  z_sum <- setNames(rep(0, length(genes)), genes)
  w_sum <- setNames(rep(0, length(genes)), genes)
  for (pt in pts) {
    idx <- which(pb_meta$Patient_label == pt)
    if (length(idx) < 6) next
    bins <- pb_meta$axis_bin[idx]
    ord <- order(bins)
    bins <- bins[ord]
    m <- expr_mat[, idx, drop = FALSE][, ord, drop = FALSE]
    r <- apply(m, 1, function(v) suppressWarnings(cor(v, bins, method = "spearman")))
    r[is.na(r)] <- 0
    r <- pmax(pmin(r, 0.999999), -0.999999)
    z <- atanh(r)
    w <- max(length(unique(bins)) - 3, 1)
    z_sum[names(z)] <- z_sum[names(z)] + z * w
    w_sum[names(z)] <- w_sum[names(z)] + w
  }
  tanh(z_sum / pmax(w_sum, 1e-9))
}

run_program_pseudotime <- function(sce_obj, axis_col = "SSIprog", n_bins = 20, assay = "RNA", slot = "data") {
  meta <- sce_obj@meta.data %>% mutate(cell = rownames(.)) %>% filter(!is.na(.data[[axis_col]]))
  meta$axis_bin <- ave(meta[[axis_col]], meta$Patient_label, FUN = function(x) dplyr::ntile(x, n_bins))
  sce_axis <- subset(sce_obj, cells = meta$cell)
  sce_axis$axis_bin <- meta$axis_bin[match(rownames(sce_axis@meta.data), meta$cell)]
  sce_axis$pb <- paste(sce_axis$Patient_label, sce_axis$axis_bin, sep = "__")
  avg <- AverageExpression(sce_axis, assays = assay, slot = slot, group.by = "pb", verbose = FALSE)[[assay]]
  pb_meta <- data.frame(pb = colnames(avg)) %>% separate(pb, into = c("Patient_label", "axis_bin"), sep = "__") %>% mutate(axis_bin = as.integer(axis_bin))
  rank_cor <- fisher_meta_cor(avg, pb_meta)
  rank_cor <- sort(rank_cor, decreasing = TRUE)
  list(rank_cor = rank_cor, pb_meta = pb_meta, avg = avg, sce_axis = sce_axis)
}

