## 5. IDH-wildtype GBM: inferCNV-based malignant-cell definition
############################################################

if (!"Malignancy" %in% colnames(sce@meta.data)) {
  message("Running inferCNV-based malignant-cell annotation. This step can take time.")

  suppressPackageStartupMessages({
    library(AnnoProbe)
    library(infercnv)
  })

  sce$cluster <- as.character(sce$seurat_clusters)
  ref_types <- c("Endothelial", "TAMs")
  sce_cnv_pool <- subset(sce, subset = celltype %in% c("Tumor", ref_types))

  n_tumor_per_cluster <- 80
  n_ref_per_type <- 400
  min_cells_cluster <- 30

  meta_pool <- sce_cnv_pool@meta.data %>% mutate(cell = rownames(.))

  tumor_cells <- meta_pool %>%
    filter(celltype == "Tumor") %>%
    group_by(cluster) %>%
    group_modify(~{
      n <- nrow(.x)
      if (n <= min_cells_cluster) return(.x)
      .x %>% slice_sample(n = min(n_tumor_per_cluster, n))
    }) %>%
    ungroup() %>% pull(cell)

  ref_cells <- meta_pool %>%
    filter(celltype %in% ref_types) %>%
    group_by(celltype) %>%
    group_modify(~{
      n <- nrow(.x)
      .x %>% slice_sample(n = min(n_ref_per_type, n))
    }) %>%
    ungroup() %>% pull(cell)

  cells_sub <- unique(c(tumor_cells, ref_cells))
  sce_sub <- subset(sce_cnv_pool, cells = cells_sub)
  counts_sub <- GetAssayData(sce_sub, slot = "counts")

  geneInfor <- AnnoProbe::annoGene(rownames(counts_sub), "SYMBOL", "human")
  geneInfor <- geneInfor[, c(1, 4, 5, 6)]
  colnames(geneInfor) <- c("SYMBOL", "chr", "start", "end")
  geneInfor <- geneInfor[!is.na(geneInfor$chr) & !duplicated(geneInfor$SYMBOL), ]
  geneInfor <- subset(geneInfor, !chr %in% c("chrX", "chrY", "chrM"))
  geneInfor <- geneInfor[order(geneInfor$chr, geneInfor$start), ]

  rm_genes <- c(grep("^MT-", rownames(counts_sub), value = TRUE), grep("^RP[SL]", rownames(counts_sub), value = TRUE))
  keep_genes <- setdiff(intersect(rownames(counts_sub), geneInfor$SYMBOL), rm_genes)
  counts_sub <- counts_sub[keep_genes, ]
  gm <- Matrix::rowMeans(counts_sub)
  counts_sub <- counts_sub[names(gm)[gm > 0.01], ]
  if (nrow(counts_sub) > 10000) {
    top <- names(sort(Matrix::rowMeans(counts_sub), decreasing = TRUE))[1:10000]
    counts_sub <- counts_sub[top, ]
  }

  geneInfor2 <- geneInfor[geneInfor$SYMBOL %in% rownames(counts_sub), ]
  counts_sub <- counts_sub[match(geneInfor2$SYMBOL, rownames(counts_sub)), ]
  celltype_vec <- sce_sub@meta.data[colnames(counts_sub), "celltype"]

  dir.create(GBM_INFERCNV_DIR, recursive = TRUE, showWarnings = FALSE)
  anno_file <- file.path(GBM_INFERCNV_DIR, "anno_cells.txt")
  gene_file <- file.path(GBM_INFERCNV_DIR, "gene_order.txt")

  anno_cell <- data.frame(cell = colnames(counts_sub), group = celltype_vec, stringsAsFactors = FALSE)
  write.table(anno_cell, anno_file, sep = "\t", quote = FALSE, col.names = FALSE, row.names = FALSE)
  write.table(geneInfor2, gene_file, sep = "\t", quote = FALSE, col.names = FALSE, row.names = FALSE)

  infercnv_obj <- CreateInfercnvObject(
    raw_counts_matrix = counts_sub,
    annotations_file = anno_file,
    delim = "\t",
    gene_order_file = gene_file,
    ref_group_names = ref_types
  )

  infercnv_obj <- infercnv::run(
    infercnv_obj,
    cutoff = 0.1,
    out_dir = GBM_INFERCNV_DIR,
    cluster_by_groups = TRUE,
    denoise = TRUE,
    HMM = FALSE,
    num_threads = 12
  )

  expr_cnv <- infercnv_obj@expr.data
  abs_dev <- abs(expr_cnv - 1)
  score_q90 <- apply(abs_dev, 2, quantile, probs = 0.90, na.rm = TRUE)

  df_score <- data.frame(cell = colnames(expr_cnv), score_q90 = as.numeric(score_q90)) %>%
    left_join(sce_sub@meta.data %>% mutate(cell = rownames(.)) %>% select(cell, celltype, cluster), by = "cell")

  ref_df <- df_score %>% filter(celltype %in% ref_types)
  km <- kmeans(ref_df$score_q90, centers = 2)
  ref_df$km <- km$cluster
  low_k <- ref_df %>% group_by(km) %>% summarise(mu = mean(score_q90), .groups = "drop") %>% arrange(mu) %>% slice(1) %>% pull(km)
  clean_ref_scores <- ref_df %>% filter(km == low_k) %>% pull(score_q90)
  thr <- quantile(clean_ref_scores, 0.95, na.rm = TRUE)

  df_cl <- df_score %>%
    filter(celltype == "Tumor") %>%
    group_by(cluster) %>%
    summarise(
      med = median(score_q90, na.rm = TRUE),
      frac_hi = mean(score_q90 > thr, na.rm = TRUE),
      n = n(),
      .groups = "drop"
    )

  malignant_clusters <- df_cl %>% filter(frac_hi >= 0.20 | med > thr) %>% pull(cluster)

  sce$cluster <- as.character(sce$seurat_clusters)
  sce$Malignancy <- "Non_malignant"
  sce$Malignancy[sce$celltype == "Tumor" & sce$cluster %in% malignant_clusters] <- "Malignant"

  saveRDS(sce, GBM_ANNO_RDS)
}

