  group_by(care_id, patient_id = patient_id_derived, timepoint_number, timepoint_desc, idh_codel_subtype) %>%
  summarise(Myeloid_fraction = sum(Fraction[Is_myeloid], na.rm = TRUE), N_total = unique(N_total)[1], .groups = "drop")

sample_summary_mut2 <- sample_summary_mut %>%
  left_join(mes_fraction, by = c("care_id", "patient_id", "timepoint_number", "timepoint_desc", "idh_codel_subtype")) %>%
  left_join(myeloid_fraction, by = c("care_id", "patient_id", "timepoint_number", "timepoint_desc", "idh_codel_subtype"))

paired_change_mut <- sample_summary_mut2 %>%
  filter(timepoint_number %in% c(1, 2)) %>%
  group_by(patient_id) %>%
  filter(all(c(1, 2) %in% timepoint_number)) %>%
  ungroup() %>%
  select(patient_id, idh_codel_subtype, timepoint_number, SSI_median, SPS_median, IMS_median, MES_fraction, Myeloid_fraction, Cycling_fraction) %>%
  pivot_wider(names_from = timepoint_number,
              values_from = c(SSI_median, SPS_median, IMS_median, MES_fraction, Myeloid_fraction, Cycling_fraction),
              names_glue = "{.value}_T{timepoint_number}") %>%
  mutate(
    Delta_SSI = SSI_median_T2 - SSI_median_T1,
    Delta_SPS = SPS_median_T2 - SPS_median_T1,
    Delta_IMS = IMS_median_T2 - IMS_median_T1,
    Delta_MES = MES_fraction_T2 - MES_fraction_T1,
    Delta_Myeloid = Myeloid_fraction_T2 - Myeloid_fraction_T1,
    Delta_Cycling = Cycling_fraction_T2 - Cycling_fraction_T1
  )

write.csv(paired_change_mut, file.path(IDHMUT_OUT_DIR, "paired_longitudinal_change_table_SYN_IMR.csv"), row.names = FALSE)

cor_delta_mes <- cor.test(paired_change_mut$Delta_SSI, paired_change_mut$Delta_MES, method = "spearman", exact = FALSE)
cor_delta_myeloid <- cor.test(paired_change_mut$Delta_SSI, paired_change_mut$Delta_Myeloid, method = "spearman", exact = FALSE)

p4R_delta_mes <- ggplot(paired_change_mut, aes(x = Delta_MES, y = Delta_SSI)) +
  geom_hline(yintercept = 0, linetype = "dashed", linewidth = 0.4) +
  geom_vline(xintercept = 0, linetype = "dashed", linewidth = 0.4) +
  geom_point(aes(shape = idh_codel_subtype), size = 2.7, alpha = 0.9) +
  geom_smooth(method = "lm", se = TRUE, color = "black", linewidth = 0.75) +
  annotate("text", x = Inf, y = Inf,
           label = paste0("Spearman ρ = ", round(unname(cor_delta_mes$estimate), 2), "\n", format_p(cor_delta_mes$p.value)),
           hjust = 1.08, vjust = 1.25, size = 3.5) +
  labs(title = "IDH-mutant SSI shift and MES-like transition", x = expression(Delta*"MES-like fraction"), y = expression(Delta*"SSIprog"), shape = "Tumor type") +
  theme_article

ggsave(file.path(FIG_DIR, "Fig4R_IDHmut_delta_SSI_vs_delta_MES.pdf"), p4R_delta_mes, width = 6, height = 4.5, device = cairo_pdf)

pS5M_delta_myeloid_mut <- ggplot(paired_change_mut, aes(x = Delta_Myeloid, y = Delta_SSI)) +
  geom_hline(yintercept = 0, linetype = "dashed", linewidth = 0.4) +
  geom_vline(xintercept = 0, linetype = "dashed", linewidth = 0.4) +
  geom_point(aes(shape = idh_codel_subtype), size = 2.7, alpha = 0.9) +
  geom_smooth(method = "lm", se = TRUE, color = "black", linewidth = 0.75) +
  annotate("text", x = Inf, y = Inf,
           label = paste0("Spearman ρ = ", round(unname(cor_delta_myeloid$estimate), 2), "\n", format_p(cor_delta_myeloid$p.value)),
           hjust = 1.08, vjust = 1.25, size = 3.5) +
  labs(title = "IDH-mutant SSI shift and myeloid remodeling", x = expression(Delta*"myeloid/macrophage fraction"), y = expression(Delta*"SSIprog"), shape = "Tumor type") +
  theme_article

ggsave(file.path(FIG_DIR, "FigS5M_IDHmut_delta_SSI_vs_delta_myeloid.pdf"), pS5M_delta_myeloid_mut, width = 6, height = 4.5, device = cairo_pdf)

