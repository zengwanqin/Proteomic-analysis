run_ssgsea <- function(expr, gene_sets) {
  ## Compatible wrapper for old and new GSVA versions
  res <- tryCatch(
    {
      GSVA::gsva(
        expr = as.matrix(expr),
        gset.idx.list = gene_sets,
        method = "ssgsea",
        ssgsea.norm = TRUE,
        min.sz = 10,
        parallel.sz = 1
      )
    },
    error = function(e) {
      if ("ssgseaParam" %in% getNamespaceExports("GSVA")) {
        param <- GSVA::ssgseaParam(
          exprData = as.matrix(expr),
          geneSets = gene_sets,
          normalize = TRUE,
          minSize = 10
        )
        GSVA::gsva(param)
      } else {
        stop(e)
      }
    }
  )
  res
}

