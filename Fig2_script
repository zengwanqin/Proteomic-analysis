make_z_corrected <- function(model_raw, model_cor, mat, hv_top_n = 2000) {
  genes <- intersect(rownames(mat), model_cor$genes)
  X <- mat[genes, , drop = FALSE]

  mu <- model_raw$mu[genes]
  sd <- model_raw$sd[genes]
  sd[sd == 0 | !is.finite(sd)] <- 1

  z_raw <- sweep(X, 1, mu, "-")
  z_raw <- sweep(z_raw, 1, sd, "/")

  z_all <- row_z(mat)
  z_all[is.na(z_all)] <- 0

  sel <- which(gene_symbol(rownames(z_all)) %in% plasma_core)

  ps_all <- rep(0, ncol(mat))
  names(ps_all) <- colnames(mat)

  if (length(sel) >= 10) {
    ps_all <- if (isTRUE(model_cor$use_pc1)) {
      prcomp(t(z_all[sel, , drop = FALSE]), scale. = FALSE)$x[, 1]
    } else {
      colMeans(z_all[sel, , drop = FALSE], na.rm = TRUE)
    }
    ps_all <- setNames(as.numeric(ps_all), colnames(mat))
  }

  beta <- model_cor$beta[genes]
  beta[!is.finite(beta)] <- 0

  z_cor <- z_raw - beta %o% ps_all[colnames(z_raw)]

  rv <- rowVars(z_cor, na.rm = TRUE)
  hv <- order(rv, decreasing = TRUE)[seq_len(min(hv_top_n, length(rv)))]

  z_cor[hv, , drop = FALSE]
}

