run_go <- function(symbols, ont = "BP") {
  eg <- bitr(
    symbols,
    fromType = "SYMBOL",
    toType = "ENTREZID",
    OrgDb = org.Hs.eg.db
  )

  enrichGO(
    gene = unique(eg$ENTREZID),
    OrgDb = org.Hs.eg.db,
    keyType = "ENTREZID",
    ont = ont,
    pAdjustMethod = "BH",
    readable = TRUE
  ) %>%
    as.data.frame()
}

