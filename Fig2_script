build_centroid_model <- function(train_mat, label_df, plasma_correct = TRUE, use_pc1 = TRUE) {
  stopifnot(is.matrix(train_mat))

  label_df <- label_df %>%
    filter(Sample %in% colnames(train_mat)) %>%
    arrange(match(Sample, colnames(train_mat)))

  train_mat <- train_mat[, label_df$Sample, drop = FALSE]

  sym <- gene_symbol(rownames(train_mat))
  keep_hard <- !(is_ig(sym) | is_rbc(sym))

  X <- train_mat[keep_hard, , drop = FALSE]

  mu <- rowMeans(X, na.rm = TRUE)
  sd <- rowSds(X, na.rm = TRUE)
  sd[sd == 0 | !is.finite(sd)] <- 1

  z <- sweep(X, 1, mu, "-")
  z <- sweep(z, 1, sd, "/")

  ps <- rep(0, ncol(train_mat))
  names(ps) <- colnames(train_mat)

  if (plasma_correct) {
    z_all <- row_z(train_mat)
    z_all[is.na(z_all)] <- 0

    sel <- which(gene_symbol(rownames(z_all)) %in% plasma_core)

    if (length(sel) >= 10) {
      ps <- if (use_pc1) {
        prcomp(t(z_all[sel, , drop = FALSE]), scale. = FALSE)$x[, 1]
      } else {
        colMeans(z_all[sel, , drop = FALSE], na.rm = TRUE)
      }
      ps <- setNames(as.numeric(ps), colnames(train_mat))
    }
  }

  if (plasma_correct) {
    beta <- apply(z, 1, function(y) {
      ok <- is.finite(y) & is.finite(ps)
      if (sum(ok) < 8) return(0)
      as.numeric(coef(MASS::rlm(y[ok] ~ ps[ok]))[2])
    })

    beta[!is.finite(beta)] <- 0
    z_res <- z - beta %o% ps[colnames(z)]
  } else {
    beta <- rep(0, nrow(z))
    names(beta) <- rownames(z)
    z_res <- z
  }

  lab <- label_df$Subtype
  names(lab) <- label_df$Sample

  cent_SYN <- rowMeans(z_res[, lab[colnames(z_res)] == "SYN", drop = FALSE], na.rm = TRUE)
  cent_IMR <- rowMeans(z_res[, lab[colnames(z_res)] == "IMR", drop = FALSE], na.rm = TRUE)

  list(
    genes = names(mu),
    mu = mu,
    sd = sd,
    beta = beta,
    plasma_correct = plasma_correct,
    use_pc1 = use_pc1,
    cent_SYN = cent_SYN,
    cent_IMR = cent_IMR,
    train_labels = label_df
  )
}

project_centroid_model <- function(model, mat, tau_margin = 0.22, tau_r = 0.055) {
  X0 <- as.matrix(mat)
  storage.mode(X0) <- "double"

  genes <- intersect(model$genes, rownames(X0))
  X <- X0[genes, , drop = FALSE]

  zX <- sweep(X, 1, model$mu[genes], "-")
  zX <- sweep(zX, 1, model$sd[genes], "/")

  ps_all <- rep(0, ncol(X0))
  names(ps_all) <- colnames(X0)

  if (model$plasma_correct) {
    z_all <- row_z(X0)
    z_all[is.na(z_all)] <- 0

    sel <- which(gene_symbol(rownames(z_all)) %in% plasma_core)

    if (length(sel) >= 10) {
      ps_all <- if (isTRUE(model$use_pc1)) {
        prcomp(t(z_all[sel, , drop = FALSE]), scale. = FALSE)$x[, 1]
      } else {
        colMeans(z_all[sel, , drop = FALSE], na.rm = TRUE)
      }
      ps_all <- setNames(as.numeric(ps_all), colnames(X0))
    }
  }

  if (model$plasma_correct) {
    b <- model$beta[genes]
    b[!is.finite(b)] <- 0
    zX_res <- zX - b %o% ps_all[colnames(zX)]
  } else {
    zX_res <- zX
  }

  sp_cor <- function(x, y) {
    suppressWarnings(cor(x, y, method = "spearman", use = "pairwise.complete.obs"))
  }

  rho_SYN <- apply(zX_res, 2, function(v) sp_cor(v, model$cent_SYN[genes]))
  rho_IMR <- apply(zX_res, 2, function(v) sp_cor(v, model$cent_IMR[genes]))

  SSIcentroid <- rho_SYN - rho_IMR
  MaxR <- pmax(rho_SYN, rho_IMR)

  PredSubtype <- ifelse(
    MaxR < tau_r,
    "Mixed",
    ifelse(
      abs(SSIcentroid) < tau_margin,
      "Mixed",
      ifelse(rho_SYN >= rho_IMR, "SYN", "IMR")
    )
  )

  res <- tibble(
    Sample = colnames(zX_res),
    rho_SYN = as.numeric(rho_SYN),
    rho_IMR = as.numeric(rho_IMR),
    SSIcentroid = as.numeric(SSIcentroid),
    MaxR = as.numeric(MaxR),
    PlasmaScore = as.numeric(ps_all[colnames(zX_res)]),
    PredSubtype = factor(PredSubtype, levels = c("SYN", "IMR", "Mixed"))
  )

  train_df <- model$train_labels
  train_samps <- intersect(train_df$Sample, res$Sample)

  if (length(train_samps) > 0) {
    res <- res %>%
      left_join(
        train_df %>% dplyr::select(Sample, TrueSubtype = Subtype),
        by = "Sample"
      )

    ## Discovery set uses curated labels
    res$PredSubtype[match(train_samps, res$Sample)] <-
      res$TrueSubtype[match(train_samps, res$Sample)]
  } else {
    res$TrueSubtype <- NA_character_
  }

  res
}

