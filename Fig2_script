`%||%` <- function(a, b) if (!is.null(a)) a else b

gene_symbol <- function(x) {
  x <- as.character(x)
  x <- ifelse(grepl("_", x), sub("^.*_", "", x), x)
  x <- sub("\\|.*$", "", x)
  x <- sub("\\..*$", "", x)
  toupper(x)
}

is_ig <- function(sym) {
  grepl("^(IGHV|IGKV|IGLV|IGHJ|IGKJ|IGLJ|IGHC|IGKC|IGLC|IG[HKL])", sym)
}

is_rbc <- function(sym) {
  sym %in% c("HBA1", "HBA2", "HBB", "HBD", "ALAS2", "CA1", "CA2")
}

row_z <- function(M) {
  M <- as.matrix(M)
  Z <- t(scale(t(M)))
  Z[!is.finite(Z)] <- NA
  Z
}

safe_num <- function(x) {
  suppressWarnings(as.numeric(as.character(x)))
}

first_non_na <- function(x) {
  x <- x[!is.na(x) & x != ""]
  if (length(x) == 0) NA else x[1]
}

infer_region <- function(x) {
  x <- as.character(x)
  dplyr::case_when(
    str_detect(x, "^Chnsrmyy") ~ "TC",
    str_detect(x, "^Bhnsrmyy") ~ "TE",
    str_detect(x, "^Nhnsrmyy") ~ "AB",
    TRUE                      ~ "Unknown"
  )
}

infer_timepoint_from_sample <- function(x) {
  x <- as.character(x)
  dplyr::case_when(
    str_detect(x, "hnsrmyy1") ~ "Primary",
    str_detect(x, "hnsrmyy2") ~ "Recurrent",
    str_detect(x, "hnsrmyy3") ~ "SecondRec",
    str_detect(x, "^Nhnsrmyy") ~ "Reference",
    TRUE ~ "Unknown"
  )
}

normalize_idh <- function(x) {
  x <- as.character(x)
  dplyr::case_when(
    str_detect(x, "突变|mut|MUT|IDH-MUT|IDH mutant") ~ "IDH-mutant",
    str_detect(x, "野生|wt|WT|IDH-WT|IDH wild") ~ "IDH-wildtype",
    TRUE ~ "Unknown"
  )
}

normalize_grade <- function(x) {
  x <- as.character(x)
  dplyr::case_when(
    str_detect(x, "2|II") ~ "G2",
    str_detect(x, "3|III") ~ "G3",
    str_detect(x, "4|IV") ~ "G4",
    TRUE ~ "Unknown"
  )
}

