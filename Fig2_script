## 23. Figure S3F: alternative classifier cross-validation
############################################################

cv_data <- disc_for_de_z
cv_labels <- discovery_label_df$Subtype
names(cv_labels) <- discovery_label_df$Sample

## Use top 50 DE proteins as features
feature50 <- deg_df %>%
  filter(Direction %in% c("SYN", "IMR")) %>%
  arrange(adj.P.Val) %>%
  slice_head(n = 50) %>%
  pull(Symbol)

feature50 <- intersect(feature50, rownames(cv_data))
X_cv <- t(cv_data[feature50, discovery_label_df$Sample, drop = FALSE])
X_cv[!is.finite(X_cv)] <- 0
y_cv <- factor(discovery_label_df$Subtype, levels = c("SYN", "IMR"))

folds <- caret::createFolds(y_cv, k = min(10, length(y_cv)), returnTrain = FALSE)

cv_res <- map_dfr(seq_along(folds), function(i) {
  test_idx <- folds[[i]]
  train_idx <- setdiff(seq_along(y_cv), test_idx)

  x_train <- X_cv[train_idx, , drop = FALSE]
  x_test  <- X_cv[test_idx, , drop = FALSE]
  y_train <- y_cv[train_idx]
  y_test  <- y_cv[test_idx]

  ## Elastic-net logistic regression
  cvfit <- cv.glmnet(
    x = x_train,
    y = y_train,
    family = "binomial",
    alpha = 0.5,
    type.measure = "class"
  )

  prob_enet <- as.numeric(predict(cvfit, newx = x_test, s = "lambda.min", type = "response"))
  pred_enet <- ifelse(prob_enet > 0.5, levels(y_cv)[2], levels(y_cv)[1]) %>%
    factor(levels = levels(y_cv))

  roc_enet <- tryCatch(
    as.numeric(pROC::auc(pROC::roc(y_test, prob_enet, levels = levels(y_cv), quiet = TRUE))),
    error = function(e) NA_real_
  )

  ## kNN
  pred_knn <- class::knn(train = x_train, test = x_test, cl = y_train, k = 3)
  acc_knn <- mean(pred_knn == y_test)

  tibble(
    Fold = i,
    Model = c("Elastic-net", "kNN"),
    Accuracy = c(mean(pred_enet == y_test), acc_knn),
    ROC_AUC = c(roc_enet, NA_real_)
  )
})

write.csv(
  cv_res,
  file.path(OUT_TBL_DIR, "FigS3F_classifier_cross_validation.csv"),
  row.names = FALSE
)

p_cv <- cv_res %>%
  pivot_longer(cols = c(Accuracy, ROC_AUC), names_to = "Metric", values_to = "Value") %>%
  filter(!is.na(Value)) %>%
  ggplot(aes(x = Model, y = Value, fill = Model)) +
  geom_col(
    data = ~ .x %>% group_by(Model, Metric) %>% summarise(Value = mean(Value), .groups = "drop"),
    width = 0.65,
    alpha = 0.7
  ) +
  geom_jitter(width = 0.12, size = 2, alpha = 0.8) +
  facet_wrap(~ Metric, scales = "free_y") +
  labs(x = NULL, y = "Cross-validation performance") +
  theme_classic(base_size = 12) +
  theme(
    legend.position = "none",
    panel.border = element_rect(colour = "black", fill = NA, linewidth = 0.6)
  )

