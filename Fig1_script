plot_patient_distribution <- function(df, var, title, xlab = NULL) {
  var <- rlang::ensym(var)

  dd <- df %>%
    filter(!is.na(!!var), !!var != "N/A") %>%
    count(!!var, name = "n") %>%
    mutate(
      pct = n / sum(n),
      label = paste0(n, "\n", scales::percent(pct, accuracy = 1))
    )

  ggplot(dd, aes(x = !!var, y = n)) +
    geom_col(width = 0.65, fill = "#6B7280") +
    geom_text(aes(label = label), vjust = -0.25, size = 3.5) +
    scale_y_continuous(expand = expansion(mult = c(0, 0.18))) +
    labs(title = title, x = xlab, y = "Patients") +
    theme_classic(base_size = 12) +
    theme(
      plot.title = element_text(hjust = 0.5, face = "bold"),
      axis.text.x = element_text(angle = 25, hjust = 1),
      panel.border = element_rect(color = "black", fill = NA, linewidth = 0.6)
    )
}

