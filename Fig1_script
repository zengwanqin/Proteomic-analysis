## 15. Figure S1E-G: UMAP of global proteomic profiles
## =========================================================

## Select high-variable proteins.
min_non_na_prop <- 0.70
hv_top_n <- 2000

expr <- protein_mat
keep_rows <- rowMeans(is.finite(expr)) >= min_non_na_prop
expr_f <- expr[keep_rows, , drop = FALSE]

rv <- matrixStats::rowVars(expr_f, na.rm = TRUE)
hv_idx <- order(rv, decreasing = TRUE)[seq_len(min(hv_top_n, length(rv)))]
expr_hv <- expr_f[hv_idx, , drop = FALSE]

## Impute remaining missing values by row means for UMAP.
expr_hv_imp <- expr_hv
for (i in seq_len(nrow(expr_hv_imp))) {
  v <- expr_hv_imp[i, ]
  v[!is.finite(v)] <- mean(v, na.rm = TRUE)
  expr_hv_imp[i, ] <- v
}

expr_hv_z <- t(scale(t(expr_hv_imp)))
expr_hv_z[!is.finite(expr_hv_z)] <- 0

set.seed(123)
umap_mat <- uwot::umap(
  t(expr_hv_z),
  n_neighbors = 15,
  min_dist = 0.2,
  metric = "euclidean"
)

umap_df <- as.data.frame(umap_mat) %>%
  setNames(c("UMAP1", "UMAP2")) %>%
  mutate(sample_id = rownames(t(expr_hv_z))) %>%
  left_join(sample_meta_qc, by = "sample_id") %>%
  mutate(
    time_shape = case_when(
      time_point == "Primary" ~ "Primary",
      time_point == "Recurrent" ~ "Recurrent",
      time_point == "Second recurrent" ~ "Second recurrent",
      block == "Normal brain" ~ "Normal brain",
      block == "Adjacent brain" ~ "Adjacent brain",
      TRUE ~ "Other"
    )
  )

