clean_chr <- function(x) {
  x <- as.character(x)
  x <- stringr::str_replace_all(x, "\u00A0", " ")
  x <- stringr::str_replace_all(x, "　", " ")
  x <- stringr::str_squish(x)
  x[x %in% c("", "NA", "N/A", "na", "Na", "？", "?", "NULL", "null")] <- NA_character_
  x
}

parse_date_any <- function(x) {
  if (inherits(x, "Date")) return(x)
  if (inherits(x, "POSIXt")) return(as.Date(x))

  x_chr <- clean_chr(x)
  x_chr[x_chr %in% c("至今", "？至今", "?至今", "已故 家属不愿意告知")] <- NA_character_

  out <- rep(as.Date(NA), length(x_chr))

  is_excel_num <- grepl("^\\d+(\\.\\d+)?$", x_chr) & !is.na(x_chr)
  if (any(is_excel_num)) {
    num <- suppressWarnings(as.numeric(x_chr[is_excel_num]))
    plausible <- num > 20000 & num < 60000
    tmp <- rep(as.Date(NA), length(num))
    tmp[plausible] <- as.Date(num[plausible], origin = "1899-12-30")
    out[is_excel_num] <- tmp
  }

  is_char_date <- is.na(out) & !is.na(x_chr)
  if (any(is_char_date)) {
    x2 <- x_chr[is_char_date]
    x2 <- stringr::str_replace_all(x2, "\\?", "")
    x2 <- stringr::str_replace_all(x2, "？", "")
    x2 <- stringr::str_replace_all(x2, "\\.", "/")
    x2 <- stringr::str_replace_all(x2, "-", "/")
    x2 <- stringr::str_squish(x2)

    parsed <- suppressWarnings(as.Date(x2, format = "%Y/%m/%d"))

    fail <- is.na(parsed)
    if (any(fail)) {
      parsed[fail] <- suppressWarnings(as.Date(x2[fail], format = "%Y/%m"))
    }

    fail <- is.na(parsed)
    if (any(fail)) {
      parsed[fail] <- suppressWarnings(as.Date(x2[fail], format = "%m/%d/%Y"))
    }

    out[is_char_date] <- parsed
  }

  out
}

parse_num_any <- function(x) {
  x_chr <- clean_chr(x)
  x_chr <- stringr::str_replace_all(x_chr, "？", "")
  x_chr <- stringr::str_replace_all(x_chr, "\\?", "")
  x_chr <- stringr::str_replace_all(x_chr, "天|月", "")
  x_chr <- stringr::str_extract(x_chr, "\\d+\\.?\\d*")
  suppressWarnings(as.numeric(x_chr))
}

first_non_na <- function(x) {
  x <- x[!is.na(x)]
  if (length(x) == 0) return(NA)
  x[[1]]
}

min_date_or_na <- function(x) {
  x <- x[!is.na(x)]
  if (length(x) == 0) return(as.Date(NA))
  min(x)
}

max_num_or_na <- function(x) {
  x <- x[!is.na(x)]
  if (length(x) == 0) return(NA_real_)
  max(x)
}

collapse_unique <- function(x, sep = "; ") {
  x <- unique(x[!is.na(x) & x != ""])
  if (length(x) == 0) return(NA_character_)
  paste(x, collapse = sep)
}

find_col <- function(df, candidates) {
  cn <- colnames(df)
  hit <- cn[cn %in% candidates]
  if (length(hit) > 0) return(hit[[1]])

  hit2 <- cn[stringr::str_detect(cn, paste(candidates, collapse = "|"))]
  if (length(hit2) > 0) return(hit2[[1]])

  NA_character_
}

get_col_or_na <- function(df, col) {
  if (is.na(col) || !col %in% colnames(df)) {
    rep(NA, nrow(df))
  } else {
    df[[col]]
  }
}

normalize_idh <- function(x) {
  x <- clean_chr(x)
  dplyr::case_when(
    is.na(x) ~ NA_character_,
    stringr::str_detect(x, regex("^normal$|正常|non[- ]?glioma", ignore_case = TRUE)) ~ "Normal",
    stringr::str_detect(x, regex("野生|wild|WT|Wt|wt", ignore_case = TRUE)) ~ "IDH-wild-type",
    stringr::str_detect(x, regex("突变|mut|Mut|MUT", ignore_case = TRUE)) ~ "IDH-mutant",
    TRUE ~ x
  )
}

normalize_idh_short <- function(x) {
  x <- normalize_idh(x)
  dplyr::case_when(
    x == "IDH-mutant" ~ "IDH-mut",
    x == "IDH-wild-type" ~ "IDH-wt",
    TRUE ~ "Unknown"
  )
}

normalize_sex <- function(x) {
  x <- clean_chr(x)
  dplyr::case_when(
    is.na(x) ~ NA_character_,
    x %in% c("F", "女", "Female", "female") ~ "Female",
    x %in% c("M", "男", "Male", "male") ~ "Male",
    TRUE ~ x
  )
}

normalize_grade <- function(x) {
  x <- clean_chr(x)
  dplyr::case_when(
    is.na(x) ~ NA_character_,
    stringr::str_detect(x, "4") ~ "Grade 4",
    stringr::str_detect(x, "3") ~ "Grade 3",
    stringr::str_detect(x, "2") ~ "Grade 2",
    stringr::str_detect(x, "1") ~ "Grade 1",
    TRUE ~ NA_character_
  )
}

detect_yes <- function(x) {
  x <- clean_chr(x)
  dplyr::case_when(
    is.na(x) ~ FALSE,
    stringr::str_detect(x, "未|无|否|没有") ~ FALSE,
    stringr::str_detect(
      x,
      "放疗|化疗|替莫|替莫唑胺|甲氨蝶呤|福莫司汀|长春新碱|γ刀|r刀|靶向|阿帕替尼|安罗替尼|信迪利|贝伐|免疫"
    ) ~ TRUE,
    TRUE ~ FALSE
  )
}

detect_tmz <- function(x) {
  x <- clean_chr(x)
  dplyr::case_when(
    is.na(x) ~ FALSE,
    stringr::str_detect(x, "未|无|否|没有") ~ FALSE,
    stringr::str_detect(x, "替莫|替莫唑胺|TMZ|tmz") ~ TRUE,
    TRUE ~ FALSE
  )
}

detect_other_chemo <- function(x) {
  x <- clean_chr(x)
  dplyr::case_when(
    is.na(x) ~ FALSE,
    stringr::str_detect(x, "未|无|否|没有") ~ FALSE,
    stringr::str_detect(x, "甲氨蝶呤|福莫司汀|长春新碱") ~ TRUE,
    stringr::str_detect(x, "化疗") &
      !stringr::str_detect(x, "替莫|替莫唑胺|TMZ|tmz") ~ TRUE,
    TRUE ~ FALSE
  )
}

detect_target <- function(x) {
  x <- clean_chr(x)
  dplyr::case_when(
    is.na(x) ~ FALSE,
    stringr::str_detect(x, "未|无|否|没有") ~ FALSE,
    stringr::str_detect(x, "靶向|免疫|阿帕替尼|安罗替尼|信迪利|贝伐|PD|PD-1|PD1") ~ TRUE,
    TRUE ~ FALSE
  )
}

get_surgery_index_from_id <- function(sample_id) {
  sid <- as.character(sample_id)
  dplyr::case_when(
    stringr::str_detect(sid, "myy1") ~ 1L,
    stringr::str_detect(sid, "myy2") ~ 2L,
    stringr::str_detect(sid, "myy3") ~ 3L,
    TRUE ~ NA_integer_
  )
}

get_timepoint_from_index <- function(idx, force_na = FALSE) {
  dplyr::case_when(
    force_na ~ "N/A",
    is.na(idx) ~ "N/A",
    idx == 1L ~ "Primary",
    idx == 2L ~ "Recurrent",
    idx >= 3L ~ "Second recurrent",
    TRUE ~ "N/A"
  )
}

infer_region_from_sample <- function(sample_id) {
  dplyr::case_when(
    stringr::str_detect(sample_id, "^Chnsrmyy") ~ "Tumor core",
    stringr::str_detect(sample_id, "^Bhnsrmyy") ~ "Tumor edge",
    stringr::str_detect(sample_id, "^Nhnsrmyy") ~ "Adjacent brain",
    TRUE ~ "Unknown"
  )
}

row_zscore <- function(mat) {
  mat <- as.matrix(mat)
  z <- t(scale(t(mat)))
  z[!is.finite(z)] <- NA
  z
}

safe_read_sheet <- function(path, sheet) {
  readxl::read_excel(path, sheet = sheet, guess_max = 10000)
}


