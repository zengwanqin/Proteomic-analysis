## 3. Read and standardize sample-level metadata
## =========================================================

standardize_region_table <- function(df, region_label) {
  required_cn <- c("编号", "病理号", "姓名", "性别", "年龄", "分子状态")
  missing_cn <- setdiff(required_cn, colnames(df))

  if (length(missing_cn) > 0) {
    stop(
      "Missing columns in Table1 sheet for ",
      region_label,
      ": ",
      paste(missing_cn, collapse = ", ")
    )
  }

  df %>%
    transmute(
      sample_id = clean_chr(.data[["编号"]]),
      pathology_id = clean_chr(.data[["病理号"]]),
      patient_name = clean_chr(.data[["姓名"]]),
      sex_raw = clean_chr(.data[["性别"]]),
      birth_raw = .data[["年龄"]],
      idh_raw = clean_chr(.data[["分子状态"]]),
      region_raw = region_label
    ) %>%
    filter(!is.na(sample_id)) %>%
    filter(!stringr::str_detect(sample_id, "无|删除|已删除")) %>%
    mutate(
      region = case_when(
        region_raw == "core" ~ "Tumor core",
        region_raw == "edge" ~ "Tumor edge",
        region_raw == "normal" ~ "Adjacent brain",
        TRUE ~ region_raw
      ),
      birth_date_sample = parse_date_any(birth_raw),
      sex = normalize_sex(sex_raw),
      idh_status_sample = normalize_idh(idh_raw),
      surgery_index = get_surgery_index_from_id(sample_id),
      time_point_from_id = get_timepoint_from_index(surgery_index)
    )
}

core_raw   <- safe_read_sheet(table1_file, "core")
edge_raw   <- safe_read_sheet(table1_file, "edge")
normal_raw <- safe_read_sheet(table1_file, "normal")

samples_all <- bind_rows(
  standardize_region_table(core_raw, "core"),
  standardize_region_table(edge_raw, "edge"),
  standardize_region_table(normal_raw, "normal")
)

## Non-glioma normal brain controls.
## Nhnsrmyy01 is glioma-associated adjacent brain.
non_glioma_normal_ids <- c(
  "Nhnsrmyy02", "Nhnsrmyy03", "Nhnsrmyy04", "Nhnsrmyy05", "Nhnsrmyy06",
  "Nhnsrmyy07", "Nhnsrmyy08", "Nhnsrmyy09", "Nhnsrmyy010", "Nhnsrmyy011"
)

samples_all <- samples_all %>%
  mutate(
    tissue_source = case_when(
      sample_id %in% non_glioma_normal_ids ~ "Non-glioma normal brain",
      region == "Adjacent brain" ~ "Glioma-associated adjacent brain",
      region %in% c("Tumor core", "Tumor edge") ~ "Glioma tissue",
      TRUE ~ "Unknown"
    ),
    region = case_when(
      tissue_source == "Non-glioma normal brain" ~ "Non-glioma normal brain",
      tissue_source == "Glioma-associated adjacent brain" ~ "Adjacent brain",
      TRUE ~ as.character(region)
    )
  )


## =========================================================
## 4. Read and standardize clinical metadata
## =========================================================

clin_raw <- safe_read_sheet(table2_file, "clinical")
colnames(clin_raw) <- clean_chr(colnames(clin_raw))

col_sample_id <- find_col(clin_raw, c("编号"))
col_pathology <- find_col(clin_raw, c("病理号"))
col_name      <- find_col(clin_raw, c("姓名"))
col_sex       <- find_col(clin_raw, c("性别"))
col_birth     <- find_col(clin_raw, c("年龄"))
col_idh       <- find_col(clin_raw, c("分子状态"))
col_grade     <- find_col(clin_raw, c("WHO级别", "WHO", "级别"))
col_disease   <- find_col(clin_raw, c("疾病时间"))
col_prog      <- find_col(clin_raw, c("进展时间天", "进展时间（天）", "进展时间"))
col_surv_date <- find_col(clin_raw, c("生存日期"))
col_surv      <- find_col(clin_raw, c("生存时间"))
col_radio     <- find_col(clin_raw, c("放疗"))
col_chemo     <- find_col(clin_raw, c("化疗"))
col_target    <- find_col(clin_raw, c("靶向免疫", "靶向", "免疫"))

required_clin <- c(col_sample_id, col_name, col_birth, col_idh, col_grade, col_disease)
if (any(is.na(required_clin))) {
  stop(
    "Cannot identify required clinical columns. Detected columns are:\n",
    paste(colnames(clin_raw), collapse = ", ")
  )
}

clin <- clin_raw %>%
  transmute(
    sample_id_clin = clean_chr(.data[[col_sample_id]]),
    pathology_id_clin = clean_chr(get_col_or_na(clin_raw, col_pathology)),
    patient_name_clin = clean_chr(.data[[col_name]]),
    sex_raw_clin = clean_chr(get_col_or_na(clin_raw, col_sex)),
    birth_raw_clin = .data[[col_birth]],
    idh_raw_clin = clean_chr(.data[[col_idh]]),
    who_grade_raw = clean_chr(.data[[col_grade]]),
    disease_date_raw = .data[[col_disease]],
    progression_days_raw = get_col_or_na(clin_raw, col_prog),
    survival_date_raw = get_col_or_na(clin_raw, col_surv_date),
    survival_days_raw = get_col_or_na(clin_raw, col_surv),
    radiotherapy_raw = clean_chr(get_col_or_na(clin_raw, col_radio)),
    chemo_raw = clean_chr(get_col_or_na(clin_raw, col_chemo)),
    targeted_immuno_raw = clean_chr(get_col_or_na(clin_raw, col_target))
  ) %>%
  filter(!is.na(sample_id_clin)) %>%
  mutate(
    sex_clin = normalize_sex(sex_raw_clin),
    idh_status_clin = normalize_idh(idh_raw_clin),
    who_grade_plot = normalize_grade(who_grade_raw),
    disease_date = parse_date_any(disease_date_raw),
    birth_date_clin = parse_date_any(birth_raw_clin),
    progression_days = parse_num_any(progression_days_raw),
    survival_days = parse_num_any(survival_days_raw),
    surgery_index_clin = get_surgery_index_from_id(sample_id_clin),
    time_point_clin = get_timepoint_from_index(surgery_index_clin),
    radio_after_sampling = detect_yes(radiotherapy_raw),
    tmz_after_sampling = detect_tmz(chemo_raw),
    other_chemo_after_sampling = detect_other_chemo(chemo_raw),
    target_after_sampling = detect_target(targeted_immuno_raw)
  )

## Prior treatment before each sample acquisition.
clin_prior <- clin %>%
  arrange(patient_name_clin, disease_date, surgery_index_clin) %>%
  group_by(patient_name_clin) %>%
  mutate(
    prior_radiotherapy = lag(cumsum(replace_na(radio_after_sampling, FALSE)) > 0, default = FALSE),
    prior_tmz_chemo = lag(cumsum(replace_na(tmz_after_sampling, FALSE)) > 0, default = FALSE),
    prior_other_chemo = lag(cumsum(replace_na(other_chemo_after_sampling, FALSE)) > 0, default = FALSE),
    prior_targeted_immuno = lag(cumsum(replace_na(target_after_sampling, FALSE)) > 0, default = FALSE)
  ) %>%
  ungroup()

patient_level <- clin_prior %>%
  group_by(patient_name_clin) %>%
  summarise(
    first_disease_date = min_date_or_na(disease_date),
    birth_date_patient = first_non_na(birth_date_clin),
    sex_patient = first_non_na(sex_clin),
    idh_status_patient = first_non_na(idh_status_clin),
    age_at_diagnosis_patient = if_else(
      is.na(first_disease_date) | is.na(birth_date_patient),
      NA_real_,
      as.numeric(first_disease_date - birth_date_patient) / 365.25
    ),
    ttp_months = max_num_or_na(progression_days) / 30.44,
    os_months = max_num_or_na(survival_days) / 30.44,
    ttp_days = max_num_or_na(progression_days),
    os_days = max_num_or_na(survival_days),
    .groups = "drop"
  )

clin_for_join <- clin_prior %>%
  select(
    sample_id_clin,
    patient_name_clin,
    surgery_index_clin,
    disease_date,
    birth_date_clin,
    idh_status_clin,
    who_grade_plot,
    time_point_clin,
    prior_radiotherapy,
    prior_tmz_chemo,
    prior_other_chemo,
    prior_targeted_immuno
  )


## =========================================================
## 5. Merge sample-level and patient-level annotation
## =========================================================

fig1_anno <- samples_all %>%
  left_join(clin_for_join, by = c("sample_id" = "sample_id_clin")) %>%
  left_join(patient_level, by = c("patient_name" = "patient_name_clin"))

## Backup join by patient + surgery index.
backup_join <- samples_all %>%
  select(sample_id, patient_name, surgery_index) %>%
  left_join(
    clin_for_join,
    by = c(
      "patient_name" = "patient_name_clin",
      "surgery_index" = "surgery_index_clin"
    )
  ) %>%
  select(
    sample_id,
    disease_date_backup = disease_date,
    birth_date_clin_backup = birth_date_clin,
    idh_status_clin_backup = idh_status_clin,
    who_grade_plot_backup = who_grade_plot,
    time_point_clin_backup = time_point_clin,
    prior_radiotherapy_backup = prior_radiotherapy,
    prior_tmz_chemo_backup = prior_tmz_chemo,
    prior_other_chemo_backup = prior_other_chemo,
    prior_targeted_immuno_backup = prior_targeted_immuno
  )

fig1_anno <- fig1_anno %>%
  left_join(backup_join, by = "sample_id") %>%
  mutate(
    disease_date = coalesce(disease_date, disease_date_backup),
    birth_date_clin = coalesce(birth_date_clin, birth_date_clin_backup),
    idh_status_clin = coalesce(idh_status_clin, idh_status_clin_backup),
    who_grade_plot = coalesce(who_grade_plot, who_grade_plot_backup),
    time_point_clin = coalesce(time_point_clin, time_point_clin_backup),
    prior_radiotherapy = coalesce(prior_radiotherapy, prior_radiotherapy_backup),
    prior_tmz_chemo = coalesce(prior_tmz_chemo, prior_tmz_chemo_backup),
    prior_other_chemo = coalesce(prior_other_chemo, prior_other_chemo_backup),
    prior_targeted_immuno = coalesce(prior_targeted_immuno, prior_targeted_immuno_backup)
  ) %>%
  select(-ends_with("_backup"))

## Final plotting variables.
fig1_anno <- fig1_anno %>%
  mutate(
    age_from_sample_birth = if_else(
      !is.na(disease_date) & !is.na(birth_date_sample),
      as.numeric(disease_date - birth_date_sample) / 365.25,
      NA_real_
    ),

    pathology_year2 = suppressWarnings(as.integer(str_extract(pathology_id, "^\\d{2}"))),
    pathology_year = if_else(is.na(pathology_year2), NA_integer_, 2000L + pathology_year2),
    age_normal_control = if_else(
      tissue_source == "Non-glioma normal brain" &
        !is.na(pathology_year) &
        !is.na(birth_date_sample),
      pathology_year - as.integer(format(birth_date_sample, "%Y")),
      NA_real_
    ),

    idh_status_final = coalesce(idh_status_clin, idh_status_patient, idh_status_sample),

    block = case_when(
      tissue_source == "Non-glioma normal brain" ~ "Normal brain",
      tissue_source == "Glioma-associated adjacent brain" ~ "Adjacent brain",
      idh_status_final == "IDH-mutant" ~ "IDH-mutant glioma",
      idh_status_final == "IDH-wild-type" ~ "IDH-wild-type glioma",
      TRUE ~ "Other"
    ),

    age_years = case_when(
      block == "Normal brain" ~ age_normal_control,
      TRUE ~ coalesce(age_at_diagnosis_patient, age_from_sample_birth)
    ),

    glioma_idh_context = case_when(
      block == "Normal brain" ~ "N/A",
      idh_status_final == "IDH-mutant" ~ "IDH-mutant glioma context",
      idh_status_final == "IDH-wild-type" ~ "IDH-wild-type glioma context",
      TRUE ~ "N/A"
    ),

    time_point = case_when(
      block == "Normal brain" ~ "N/A",
      TRUE ~ get_timepoint_from_index(surgery_index, force_na = FALSE)
    ),

    who_grade_plot = case_when(
      block %in% c("Normal brain", "Adjacent brain") ~ "N/A",
      is.na(who_grade_plot) ~ "N/A",
      TRUE ~ who_grade_plot
    ),

    sex_plot = if_else(is.na(sex), "N/A", sex),

    prior_radiotherapy_plot = case_when(
      block == "Normal brain" ~ "N/A",
      prior_radiotherapy %in% TRUE ~ "Yes",
      TRUE ~ "No"
    ),
    prior_tmz_chemo_plot = case_when(
      block == "Normal brain" ~ "N/A",
      prior_tmz_chemo %in% TRUE ~ "Yes",
      TRUE ~ "No"
    ),
    prior_other_chemo_plot = case_when(
      block == "Normal brain" ~ "N/A",
      prior_other_chemo %in% TRUE ~ "Yes",
      TRUE ~ "No"
    ),
    prior_targeted_immuno_plot = case_when(
      block == "Normal brain" ~ "N/A",
      prior_targeted_immuno %in% TRUE ~ "Yes",
      TRUE ~ "No"
    ),

    ttp_months = if_else(block == "Normal brain", NA_real_, ttp_months),
    os_months = if_else(block == "Normal brain", NA_real_, os_months)
