collapse_grade_transition <- function(grade_vec, time_vec) {
  df <- data.frame(
    grade = as.character(grade_vec),
    time = as.character(time_vec),
    stringsAsFactors = FALSE
  ) %>%
    filter(!is.na(grade), grade != "N/A", !is.na(time), time != "N/A") %>%
    mutate(
      time_order = case_when(
        time == "Primary" ~ 1,
        time == "Recurrent" ~ 2,
        time == "Second recurrent" ~ 3,
        TRUE ~ 9
      )
    ) %>%
    arrange(time_order)

  if (nrow(df) == 0) return("N/A")
  paste(unique(df$grade), collapse = " -> ")
}

