############################################################
## 4. Construct matched primary-recurrent TC pairs
############################################################

tc_unique <- fig3_df %>%
  filter(
    Region == "TC",
    TimePoint %in% c("Primary", "Recurrent"),
    !is.na(PatientID),
    !is.na(PredSubtype),
    is.finite(SSIprog)
  ) %>%
  group_by(PatientID, TimePoint) %>%
  arrange(desc(abs(SSIprog)), desc(abs(SSIcentroid)), .by_group = TRUE) %>%
  slice_head(n = 1) %>%
  ungroup()

tc_pairs <- tc_unique %>%
  dplyr::select(
    PatientID, Sample, TimePoint, PredSubtype, SPS, IMS, SSIprog,
    IDH, Progress_time, Survival_time
  ) %>%
  pivot_wider(
    id_cols = PatientID,
    names_from = TimePoint,
    values_from = c(
      Sample, PredSubtype, SPS, IMS, SSIprog,
      IDH, Progress_time, Survival_time
    ),
    names_sep = "_"
  ) %>%
  filter(!is.na(Sample_Primary), !is.na(Sample_Recurrent)) %>%
  mutate(
    Subtype_Primary = as.character(PredSubtype_Primary),
    Subtype_Recurrent = as.character(PredSubtype_Recurrent),
    Transition = paste0(Subtype_Primary, "→", Subtype_Recurrent),
    Transition = ifelse(Transition %in% names(trajectory_cols), Transition, "Other"),
    Transition = factor(Transition, levels = names(trajectory_cols)),
    delta_SPS = SPS_Recurrent - SPS_Primary,
    delta_IMS = IMS_Recurrent - IMS_Primary,
    delta_SSI = SSIprog_Recurrent - SSIprog_Primary,
    IDH = coalesce(as.character(IDH_Primary), as.character(IDH_Recurrent), "Unknown"),
    IDH = factor(IDH, levels = c("IDH-mutant", "IDH-wildtype", "Unknown"))
  )

write.csv(
  tc_pairs,
  file.path(OUT_TBL_DIR, "Fig3_matched_primary_recurrent_TC_pairs.csv"),
  row.names = FALSE
)

tc_long <- tc_unique %>%
