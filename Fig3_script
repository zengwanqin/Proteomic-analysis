)

## Load matrix
protein_raw <- read.table(PATH_MAT, header = TRUE, check.names = FALSE, stringsAsFactors = FALSE)

sample_cols <- grep("^(Chnsrmyy|Bhnsrmyy|Nhnsrmyy)", colnames(protein_raw), value = TRUE)

if (!colnames(protein_raw)[1] %in% sample_cols) {
  rownames(protein_raw) <- protein_raw[[1]]
  protein_raw <- protein_raw[, sample_cols, drop = FALSE]
}

protein_mat <- as.matrix(protein_raw)
storage.mode(protein_mat) <- "double"
rownames(protein_mat) <- gene_symbol(rownames(protein_mat))

## collapse duplicated genes by highest variance
if (any(duplicated(rownames(protein_mat)))) {
  rv <- matrixStats::rowVars(protein_mat, na.rm = TRUE)
  keep <- tibble(Gene = rownames(protein_mat), row = seq_len(nrow(protein_mat)), var = rv) %>%
    group_by(Gene) %>%
    slice_max(var, n = 1, with_ties = FALSE) %>%
    ungroup()
  protein_mat <- protein_mat[keep$row, , drop = FALSE]
  rownames(protein_mat) <- keep$Gene
}

row_z <- function(M) {
  Z <- t(scale(t(as.matrix(M))))
  Z[!is.finite(Z)] <- NA
  Z
}

Z <- row_z(protein_mat)

mean_score <- function(Z, genes) {
  genes <- intersect(gene_symbol(genes), rownames(Z))
  if (length(genes) < 3) return(rep(NA_real_, ncol(Z)))
  colMeans(Z[genes, , drop = FALSE], na.rm = TRUE)
}

pathway_scores <- map_dfc(pathway_list, ~ mean_score(Z, .x)) %>%
  as.data.frame()

colnames(pathway_scores) <- names(pathway_list)
rownames(pathway_scores) <- colnames(Z)

pair_samples <- tc_pairs %>%
  dplyr::select(
    PatientID,
    Sample_Primary,
    Sample_Recurrent,
    Subtype_Recurrent,
    delta_SSI
  ) %>%
  filter(Sample_Primary %in% rownames(pathway_scores),
         Sample_Recurrent %in% rownames(pathway_scores))

path_delta <- sapply(seq_len(nrow(pair_samples)), function(i) {
  s_re <- pair_samples$Sample_Recurrent[i]
  s_pr <- pair_samples$Sample_Primary[i]
  as.numeric(pathway_scores[s_re, ] - pathway_scores[s_pr, ])
})

rownames(path_delta) <- colnames(pathway_scores)
colnames(path_delta) <- paste0("Pt", pair_samples$PatientID)

col_order <- pair_samples %>%
  arrange(delta_SSI) %>%
  mutate(col = paste0("Pt", PatientID))

path_delta <- path_delta[, col_order$col, drop = FALSE]

ha_col <- HeatmapAnnotation(
  Recurrent_state = factor(col_order$Subtype_Recurrent, levels = c("SYN", "IMR", "Mixed")),
  Delta_SSI = col_order$delta_SSI,
  col = list(
    Recurrent_state = sub_cols,
    Delta_SSI = colorRamp2(
      c(min(col_order$delta_SSI, na.rm = TRUE), 0, max(col_order$delta_SSI, na.rm = TRUE)),
      c("#2166AC", "#F7F7F7", "#B2182B")
    )
  ),
  annotation_name_side = "left"
)

max_abs <- max(abs(path_delta), na.rm = TRUE)

ht_fig3F <- Heatmap(
  path_delta,
  name = "Δ score\n(Recurrent − Primary)",
  col = colorRamp2(c(-max_abs, 0, max_abs), c("#2166AC", "#F7F7F7", "#B2182B")),
  cluster_rows = FALSE,
  cluster_columns = FALSE,
  top_annotation = ha_col,
  show_column_names = FALSE,
  column_title = "Figure 3F. Recurrent-minus-primary pathway-score changes"
)

pdf(file.path(OUT_FIG_DIR, "Fig3F_delta_pathway_score_heatmap.pdf"), width = 8, height = 3.8)
draw(ht_fig3F, heatmap_legend_side = "right", annotation_legend_side = "right")
dev.off()

write.csv(
  as.data.frame(path_delta) %>% rownames_to_column("Pathway"),
  file.path(OUT_TBL_DIR, "Fig3F_delta_pathway_score_matrix.csv"),
  row.names = FALSE
)

