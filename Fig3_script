############################################################
## 1. Basic functions
############################################################

gene_symbol <- function(x) {
  x <- as.character(x)
  x <- ifelse(grepl("_", x), sub("^.*_", "", x), x)
  x <- sub("\\|.*$", "", x)
  x <- sub("\\..*$", "", x)
  toupper(trimws(x))
}

safe_num <- function(x) {
  suppressWarnings(as.numeric(as.character(x)))
}

first_non_na <- function(x) {
  x <- x[!is.na(x) & x != ""]
  if (length(x) == 0) NA else x[1]
}

pick_unique <- function(x, prefer = c("max", "min", "first")[1]) {
  u <- unique(na.omit(safe_num(x)))
  if (length(u) == 0) return(NA_real_)
  if (length(u) == 1) return(u[1])
  switch(prefer, max = max(u), min = min(u), first = u[1])
}

infer_region <- function(x) {
  x <- as.character(x)
  dplyr::case_when(
    stringr::str_detect(x, "^Chnsrmyy") ~ "TC",
    stringr::str_detect(x, "^Bhnsrmyy") ~ "TE",
    stringr::str_detect(x, "^Nhnsrmyy") ~ "AB",
    TRUE ~ "Unknown"
  )
}

infer_timepoint_from_sample <- function(x) {
  x <- as.character(x)
  dplyr::case_when(
    stringr::str_detect(x, "hnsrmyy1") ~ "Primary",
    stringr::str_detect(x, "hnsrmyy2") ~ "Recurrent",
    stringr::str_detect(x, "hnsrmyy3") ~ "Recurrent",
    TRUE ~ "Unknown"
  )
}

normalize_timepoint <- function(x) {
  x <- as.character(x)
  dplyr::case_when(
    x %in% c("Primary", "primary", "C1", "初发", "初诊", "Pr") ~ "Primary",
    x %in% c("Recurrent", "recurrent", "C2", "C3", "复发", "进展", "Re") ~ "Recurrent",
    TRUE ~ NA_character_
  )
}

normalize_idh <- function(x) {
  x0 <- tolower(as.character(x))
  dplyr::case_when(
    stringr::str_detect(x0, "mut|突变") ~ "IDH-mutant",
    stringr::str_detect(x0, "wt|wild|野生") ~ "IDH-wildtype",
    TRUE ~ "Unknown"
  )
}

save_pdf_png <- function(plot, filename, width = 5, height = 4) {
  ggsave(
    file.path(OUT_FIG_DIR, paste0(filename, ".pdf")),
    plot,
    width = width,
    height = height,
    useDingbats = FALSE
  )
  ggsave(
    file.path(OUT_FIG_DIR, paste0(filename, ".png")),
    plot,
    width = width,
    height = height,
    dpi = 300
  )
}

theme_pub <- function(base_size = 11) {
  theme_classic(base_size = base_size) +
    theme(
      axis.text = element_text(color = "black"),
      axis.title = element_text(face = "bold"),
      panel.border = element_rect(color = "black", fill = NA, linewidth = 0.6),
      plot.title = element_text(face = "bold", hjust = 0),
      legend.title = element_text(face = "bold")
    )
}

