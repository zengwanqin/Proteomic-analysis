timeline_pts <- meta_std %>%
  filter(
    TimePoint %in% c("Primary", "Recurrent"),
    !is.na(PatientID)
  ) %>%
  group_by(PatientID, TimePoint) %>%
  summarise(
    IDH = first_non_na(IDH),
    Progress_month = ifelse(TimePoint[1] == "Primary", 0, pick_unique(Progress_time, prefer = "max") / 30.44),
    .groups = "drop"
  ) %>%
  filter(PatientID %in% tc_pairs$PatientID) %>%
  mutate(
    Progress_month = ifelse(TimePoint == "Primary", 0, Progress_month),
    TimePoint = factor(TimePoint, levels = c("Primary", "Recurrent")),
    IDH = factor(IDH, levels = c("IDH-mutant", "IDH-wildtype", "Unknown"))
  )

timeline_seg <- timeline_pts %>%
  group_by(PatientID) %>%
  summarise(
    x_start = 0,
    x_end = max(Progress_month, na.rm = TRUE),
    .groups = "drop"
  ) %>%
  arrange(x_end, PatientID)

timeline_pts <- timeline_pts %>%
  mutate(PatientID_f = factor(PatientID, levels = timeline_seg$PatientID))

timeline_seg <- timeline_seg %>%
  mutate(PatientID_f = factor(PatientID, levels = timeline_seg$PatientID))

