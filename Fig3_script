pred_df <- read.csv(PATH_PRED, stringsAsFactors = FALSE)

## Standardize metadata
meta_std <- meta_all %>%
  mutate(
    Sample = if ("编号" %in% names(.)) 编号 else rownames(.),
    PatientID = if ("PatientID" %in% names(.)) PatientID else 姓名,
    Region_raw = if ("TissueRegion" %in% names(.)) TissueRegion else NA_character_,
    Region = case_when(
      Region_raw %in% c("C", "Center", "TC", "Tumor core") ~ "TC",
      Region_raw %in% c("B", "E", "Edge", "TE", "Tumor edge") ~ "TE",
      Region_raw %in% c("N", "Normal", "AB", "Adjacent brain") ~ "AB",
      TRUE ~ infer_region(Sample)
    ),
    TimePoint_raw = if ("TimePoint" %in% names(.)) TimePoint else NA_character_,
    TimePoint = normalize_timepoint(TimePoint_raw),
    TimePoint = ifelse(is.na(TimePoint), infer_timepoint_from_sample(Sample), TimePoint),
    IDH_raw = if ("IDHStatus" %in% names(.)) IDHStatus else if ("分子状态" %in% names(.)) 分子状态 else NA_character_,
    IDH = normalize_idh(IDH_raw),
    Progress_time = if ("进展时间（天）" %in% names(.)) safe_num(`进展时间（天）`) else if ("Progress_time" %in% names(.)) safe_num(Progress_time) else NA_real_,
    Survival_time = if ("生存时间" %in% names(.)) safe_num(生存时间) else if ("Survival_time" %in% names(.)) safe_num(Survival_time) else NA_real_
  ) %>%
  dplyr::select(
    Sample, PatientID, Region, TimePoint, IDH,
    Progress_time, Survival_time, everything()
  )

## Standardize Fig2 outputs
