ssi_pair_stats <- tc_pairs %>%
  summarise(
    n_pair = n(),
    mean_delta = mean(delta_SSI, na.rm = TRUE),
    median_delta = median(delta_SSI, na.rm = TRUE),
    n_shift_to_IMR = sum(delta_SSI < 0, na.rm = TRUE),
    n_shift_to_SYN = sum(delta_SSI > 0, na.rm = TRUE),
    prop_shift_to_IMR = n_shift_to_IMR / n_pair
  )

wilcox_3c <- wilcox.test(
  tc_pairs$SSIprog_Recurrent,
  tc_pairs$SSIprog_Primary,
  paired = TRUE,
  alternative = "two.sided",
  exact = FALSE
)

write.csv(
  bind_cols(ssi_pair_stats, tibble(p_wilcox = wilcox_3c$p.value)),
  file.path(OUT_TBL_DIR, "Fig3C_paired_SSI_shift_statistics.csv"),
  row.names = FALSE
)

p_label_3c <- paste0(
  "ΔSSI = ", sprintf("%.2f", ssi_pair_stats$mean_delta),
  "\nWilcoxon P = ", signif(wilcox_3c$p.value, 2)
)

