p_delta_by_traj <- function(metric_name, ylab, filename) {
  dat <- delta_long %>% filter(Metric == metric_name)

  p <- ggplot(dat, aes(x = Transition, y = Delta, fill = Transition)) +
    geom_hline(yintercept = 0, linetype = "dashed", colour = "grey50") +
    geom_violin(trim = FALSE, alpha = 0.35, colour = NA) +
    geom_boxplot(width = 0.18, outlier.shape = NA, alpha = 0.9) +
    geom_jitter(aes(colour = IDH), width = 0.08, size = 2, alpha = 0.85) +
    scale_fill_manual(values = trajectory_cols, drop = FALSE) +
    scale_colour_manual(values = idh_cols, drop = FALSE) +
    labs(x = NULL, y = ylab, title = filename, colour = "IDH") +
    theme_pub(10) +
    theme(
      legend.position = "right",
      axis.text.x = element_text(angle = 35, hjust = 1)
    )

  save_pdf_png(p, filename, width = 5.5, height = 4.2)
  p
}

