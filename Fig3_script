## 10. Optional: Figure 3H mIF quantification
############################################################
## Input table format:
##   PatientID, Marker, TimePoint, Intensity, IDH
## Marker should include:
##   CAMKII, SYP, SYN1, C3, SERPINA3, SERPINH1

PATH_MIF <- file.path(META_DIR, "Fig3_mIF_quantification.csv")

if (file.exists(PATH_MIF)) {
  mif_df <- read.csv(PATH_MIF, stringsAsFactors = FALSE) %>%
    mutate(
      TimePoint = factor(TimePoint, levels = c("Primary", "Recurrent")),
      Marker = factor(Marker, levels = c("CAMKII", "SYP", "SYN1", "C3", "SERPINA3", "SERPINH1"))
    )

  mif_stats <- mif_df %>%
    group_by(Marker) %>%
    summarise(
      n_pair = n_distinct(PatientID),
      p_paired_t = tryCatch(
        t.test(
          Intensity[TimePoint == "Recurrent"],
          Intensity[TimePoint == "Primary"],
          paired = TRUE
        )$p.value,
        error = function(e) NA_real_
      ),
      .groups = "drop"
    )

  write.csv(
    mif_stats,
    file.path(OUT_TBL_DIR, "Fig3H_mIF_paired_ttest_statistics.csv"),
    row.names = FALSE
  )

  p_fig3H <- ggplot(mif_df, aes(x = TimePoint, y = Intensity)) +
    geom_col(
      data = mif_df %>%
        group_by(Marker, TimePoint) %>%
        summarise(mean_intensity = mean(Intensity, na.rm = TRUE), sd_intensity = sd(Intensity, na.rm = TRUE), .groups = "drop"),
      aes(y = mean_intensity, fill = TimePoint),
      width = 0.55,
      alpha = 0.65
    ) +
    geom_errorbar(
      data = mif_df %>%
        group_by(Marker, TimePoint) %>%
        summarise(mean_intensity = mean(Intensity, na.rm = TRUE), sd_intensity = sd(Intensity, na.rm = TRUE), .groups = "drop"),
      aes(y = mean_intensity, ymin = mean_intensity - sd_intensity, ymax = mean_intensity + sd_intensity),
      width = 0.18
    ) +
    geom_line(aes(group = PatientID), colour = "grey45", linetype = "dashed", alpha = 0.65) +
    geom_point(size = 2, colour = "black") +
    facet_wrap(~ Marker, scales = "free_y", nrow = 1) +
    scale_fill_manual(values = time_cols) +
    labs(
      x = NULL,
      y = "Mean fluorescence intensity",
      title = "Figure 3H. Paired mIF quantification"
    ) +
    theme_pub(10) +
    theme(legend.position = "none")

  save_pdf_png(p_fig3H, "Fig3H_mIF_paired_quantification", width = 10, height = 3.5)
}

